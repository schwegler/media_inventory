<%# Local variables: comment, matching_item, depth: 0 %>
<div class="comment-item">
  <div>
    <%= link_to user_path(comment.user), style: "z-index: 1;" do %>
      <%= user_avatar_tag(comment.user, size: 32) %>
    <% end %>
  </div>
  <div style="flex: 1;">
    <div class="tweet-meta-row">
      <%= link_to user_path(comment.user), style: "text-decoration: none; color: inherit; z-index: 1;" do %>
        <strong style="font-size: 0.95rem;"><%= comment.user.name.presence || comment.user.display_handle %></strong>
      <% end %>
      <span class="tweet-time"><%= comment.user.display_handle %></span>
      <span class="tweet-time">· <%= time_ago_in_words(comment.created_at) %></span>
    </div>
    <div style="color: #e2e8f0; word-break: break-word; line-height: 1.4; margin-bottom: 8px;"><%= format_content_with_mentions(comment.content) %></div>
    
    <% if logged_in? %>
      <div data-controller="toggle" data-toggle-hidden-class="hidden">
        <div class="post-actions tweet-actions" style="gap: 20px; color: #94a3b8;">
          <button class="btn-reply btn-unstyled tweet-action-btn" title="Reply" type="button" data-action="toggle#toggle">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
            </svg>
            <span style="font-size: 0.8rem;"><%= comment.replies.count > 0 ? comment.replies.count : '' %></span>
          </button>
          
          <%= render 'likes/like_button', item: comment, tweet_style: true %>
        </div>
      
        <div id="reply-form-<%= comment.id %>" class="hidden" style="margin-top: 8px;" data-toggle-target="element">
          <%= form_with model: Comment.new, url: comments_path, local: false, class: 'comment-form' do |cf| %>
            <%= cf.hidden_field :commentable_type, value: matching_item.class.name %>
            <%= cf.hidden_field :commentable_id, value: matching_item.id %>
            <%= cf.hidden_field :parent_id, value: comment.id %>
            <%= cf.text_field :content, placeholder: "Reply to #{comment.user.name.presence || comment.user.display_handle}...", required: true, class: 'comment-input' %>
            <%= cf.submit 'Reply', class: 'btn btn-primary comment-reply-btn' %>
            <button type="button" class="btn-unstyled cancel-reply-link" data-action="toggle#hide">Cancel</button>
          <% end %>
        </div>
      </div>
    <% end %>

  <% if comment.replies.any? %>
    <div class="comment-replies-list">
      <% comment.replies.includes(:user).each do |reply| %>
        <%= render 'shared/comment', comment: reply, matching_item: matching_item, depth: depth + 1 %>
      <% end %>
    </div>
  <% end %>
  </div>
</div>
