<div class="card-2026">
  <div class="card-2026-cover">
    <% if media_item.respond_to?(:cover_image) && media_item.cover_image.attached? %>
      <%= image_tag media_item.cover_image, alt: "Cover" %>
    <% elsif media_item.respond_to?(:thumbnail_url) && media_item.thumbnail_url.present? %>
      <img src="<%= media_item.thumbnail_url %>" alt="Cover">
    <% else %>
      <span class="fallback-emoji">
        <%= case media_item.class.name
            when 'Movie' then '🎬'
            when 'Album' then '💿'
            when 'Comic' then '📚'
            when 'TvShow' then '📺'
            when 'VideoGame' then '🎮'
            else '📦'
            end %>
      </span>
    <% end %>
  </div>
  <div class="card-2026-content">
    <h3 class="card-2026-title"><%= link_to media_item.title, media_item, data: { turbo_frame: "_top" } %></h3>
    
    <div class="card-2026-activity-meta">
      <div class="activity-user">
        <%= user_avatar_tag(activity.user, size: 20) %>
        <span class="friend-name"><%= link_to activity.user.name, activity.user %></span>
      </div>
      <div class="activity-stats">
        <% if lib_item.respond_to?(:rating) && lib_item.rating.present? %>
          <span class="friend-stars"><%= render_stars(lib_item.rating) %></span>
        <% end %>
        <% if lib_item.respond_to?(:rating) && lib_item.rating.to_f >= 4.0 %>
          <span class="heart-icon" style="color: #f43f5e; margin-left: 4px;">♥</span>
        <% end %>
      </div>
      <div class="activity-date" style="font-size: 0.8rem; color: #64748b; margin-top: 4px;">
        <%= activity.created_at.strftime("%b %d") %>
      </div>
    </div>
  </div>
</div>
