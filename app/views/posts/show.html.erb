<% content_for(:title, "#{@post.user.name.presence || @post.user.display_handle}'s Post") %>
<% content_for(:meta_description, truncate(@post.content, length: 160)) %>
<% if @post.user.avatar&.attached? %>
  <% content_for(:meta_image, url_for(@post.user.avatar)) %>
<% elsif @post.user.avatar_url.present? %>
  <% content_for(:meta_image, @post.user.avatar_url) %>
<% end %>

<div class="container" style="max-width: 600px; margin: 0 auto; padding-top: 20px;">
  <div class="post-card card" style="margin-bottom: 15px; padding: 20px; border-radius: 8px;">
    <div class="tweet-header">
      <%= link_to user_path(@post.user), class: "tweet-avatar-link" do %>
        <%= user_avatar_tag(@post.user, size: 48) %>
      <% end %>
      <div class="tweet-author-col">
        <%= link_to user_path(@post.user), class: "tweet-author-name" do %>
          <strong><%= @post.user.name.presence || @post.user.display_handle %></strong>
        <% end %>
        <div class="tweet-time"><%= time_ago_in_words(@post.created_at) %> ago</div>
      </div>
    </div>
    
    <div class="post-content tweet-body">
      <%= format_content_with_mentions(@post.content) %>
    </div>
    
    <div class="tweet-actions main-post-actions">
      <div class="tweet-action-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
        </svg>
        <span><%= @post.comments.count > 0 ? @post.comments.count : '' %></span>
      </div>

      <div class="tweet-action-item">
        <%= render 'likes/like_button', item: @post, tweet_style: true %>
      </div>
    </div>

    <div class="review-comments-box">
      <%= render 'shared/comments_box', matching_item: @post %>
    </div>
  </div>
</div>
