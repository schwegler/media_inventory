<%
  backdrop_url = nil
  if @comic.cover_image.attached?
    backdrop_url = url_for(@comic.cover_image)
  elsif @comic.thumbnail_url.present?
    backdrop_url = @comic.thumbnail_url
  end
%>

<div class="show-hero">
  <% if backdrop_url %>
    <div class="show-hero-backdrop" style="background-image: url('<%= backdrop_url %>');"></div>
  <% end %>
  <div class="show-hero-gradient"></div>

  <div class="show-hero-content">
    <div class="show-poster">
      <% if @comic.cover_image.attached? %>
        <%= image_tag @comic.cover_image, alt: "#{@comic.title} Cover" %>
      <% elsif @comic.thumbnail_url.present? %>
        <img src="<%= @comic.thumbnail_url %>" alt="<%= @comic.title %> Cover">
      <% else %>
        <div class="poster-fallback"><span class="fallback-emoji">📚</span></div>
      <% end %>
    </div>

    <div class="show-info">
      <h1 class="show-title"><%= @comic.title %> <%= "##{@comic.issue_number}" if @comic.issue_number.present? %></h1>
      <div class="show-meta">
        <span class="show-meta-label">by</span> <%= @comic.writer || 'Unknown' %> &bull; <%= @comic.publisher || 'Independent' %>
      </div>

      <% if @comic.rating.present? %>
        <div class="show-rating"><%= render_stars(@comic.rating) %></div>
      <% end %>

      <div class="show-badges">
        <% if @comic.is_collected? %>
          <span class="tracking-badge badge-collected">📁 In Collection</span>
        <% end %>
        <% if @comic.in_watchlist? %>
          <span class="tracking-badge badge-watchlist">⏳ Watchlist</span>
        <% end %>
        <% if @comic.consumed? %>
          <span class="tracking-badge badge-consumed">
            ✓ Read <%= "on #{@comic.consumed_at.strftime('%b %d, %Y')}" if @comic.consumed_at.present? %>
          </span>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="show-content">
  <%= render 'shared/media_actions_and_stream', item: @comic %>

  <% if @comic.review.present? %>
    <div class="show-review">
      <h3>Review</h3>
      <blockquote><%= simple_format(@comic.review) %></blockquote>
    </div>
  <% end %>

  <% if @comic.comic_issues.any? %>
    <div class="episodes-section" style="margin-top: 2rem;">
      <h3 style="font-size: 1.25rem; margin-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.5rem;">Editions & Issues</h3>
      <ul class="episodes-list" style="list-style: none; padding-left: 0; display: flex; flex-direction: column; gap: 8px;">
        <% @comic.comic_issues.sort_by { |i| i.release_date.to_s }.reverse.each do |issue| %>
          <li class="episode-item" style="background: rgba(30, 41, 59, 0.25); border: 1px solid rgba(255, 255, 255, 0.05); padding: 12px; border-radius: 8px; display: flex; gap: 12px; align-items: start;">
            <% if issue.thumbnail_url.present? %>
              <img src="<%= issue.thumbnail_url %>" alt="<%= issue.title %>" style="width: 50px; height: 75px; object-fit: cover; border-radius: 4px; flex-shrink: 0; border: 1px solid rgba(255,255,255,0.1);">
            <% end %>
            <div class="episode-info" style="flex: 1;">
              <div style="font-weight: 600; color: #fff; font-size: 0.95rem;">
                <%= issue.title %>
              </div>
              <div style="font-size: 0.8rem; color: #94a3b8; margin-top: 4px;">
                <% if issue.publisher.present? %>
                  Publisher: <%= issue.publisher %>
                <% end %>
                <% if issue.release_date.present? %>
                  &bull; Published: <%= issue.release_date %>
                <% end %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% stats = community_stats_for(@comic) %>
  <div class="show-community">
    <h2>Community</h2>

    <div class="show-stats-bar">
      <div class="show-stat">
        <div class="show-stat-value"><%= stats[:avg_rating] ? "#{stats[:avg_rating]} ★" : "—" %></div>
        <div class="show-stat-label">Average Rating</div>
      </div>
      <div class="show-stat">
        <div class="show-stat-value"><%= stats[:watchers].size %></div>
        <div class="show-stat-label">Readers</div>
      </div>
      <div class="show-stat">
        <div class="show-stat-value"><%= stats[:collectors].size %></div>
        <div class="show-stat-label">Collectors</div>
      </div>
    </div>

    <% if stats[:reviews].any? %>
      <h3>Community Reviews</h3>
      <div class="show-reviews-list">
        <% stats[:reviews].each do |matching_item| %>
          <div class="show-review-card">
            <div class="review-header">
              <%= user_avatar_tag(matching_item.user, size: 28) %>
              <span class="review-user"><%= matching_item.user.name.presence || matching_item.user.display_handle %></span>
              <% if matching_item.rating.present? %>
                <span class="review-rating"><%= render_stars(matching_item.rating) %></span>
              <% end %>
            </div>
            <div class="review-content"><%= simple_format(matching_item.review) %></div>
            <%= render 'shared/comments_box', matching_item: matching_item %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if stats[:watchers].any? %>
      <h3>Readers</h3>
      <div class="show-members-list">
        <% stats[:watchers].each do |user| %>
          <span class="show-member-tag"><%= user_avatar_tag(user, size: 20) %> <%= user.name.presence || user.display_handle %></span>
        <% end %>
      </div>
    <% end %>

    <% if stats[:collectors].any? %>
      <h3>Collectors</h3>
      <div class="show-members-list">
        <% stats[:collectors].each do |user| %>
          <span class="show-member-tag"><%= user_avatar_tag(user, size: 20) %> <%= user.name.presence || user.display_handle %></span>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="show-actions">
    <%= link_to '← Back', comics_path, class: 'btn btn-secondary' %>
    <a href="https://www.goodreads.com/search?q=<%= u(@comic.title) %>" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">🔗 Find on Goodreads</a>
  </div>
</div>
