<div class="page-header">
  <h1>Comics</h1>
  <%= link_to 'New Comic', new_comic_path, class: 'btn' %>
</div>

<turbo-frame id="items_list">
  <ul class="media-grid">
    <% @comics.each do |comic| %>
      <li class="media-card">
        <div class="card-icon" style="padding: 0; overflow: hidden; background: #000;">
          <% if comic.cover_image.attached? %>
            <%= image_tag comic.cover_image, alt: "Cover", style: "width: 100%; height: 100%; object-fit: cover;" %>
          <% elsif comic.thumbnail_url.present? %>
            <img src="<%= comic.thumbnail_url %>" alt="Cover" style="width: 100%; height: 100%; object-fit: cover;">
          <% else %>
            📚
          <% end %>
        </div>
        <div class="card-content">
          <h3><%= link_to comic.title, comic, data: { turbo_frame: "_top" } %></h3>
          <span class="card-meta">Writer: <%= comic.writer %></span>
        </div>
      </li>
    <% end %>
  </ul>

  <div class="pagination-wrapper">
    <%= paginate @comics %>
  </div>
</turbo-frame>
