<h1>New Comic</h1>
<%= form_for @comic do |f| %>
  <% if @comic.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@comic.errors.count, "error") %> prohibited this comic from being saved:</h2>
      <ul>
      <% @comic.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title %>
    <%= f.text_field :title, required: true %>
  </div>
  <div>
    <%= f.label :issue_number %>
    <%= f.number_field :issue_number %>
  </div>
  <div>
    <%= f.label :publisher %>
    <%= f.text_field :publisher %>
  </div>
  <div>
    <%= f.label :writer %>
    <%= f.text_field :writer %>
  </div>
  <div>
    <%= f.label :artist %>
    <%= f.text_field :artist %>
  </div>

  <div class="form-row-toggles">
    <div class="toggle-field">
      <%= f.check_box :is_collected %>
      <%= f.label :is_collected, "In Collection" %>
    </div>
    <div class="toggle-field">
      <%= f.check_box :in_watchlist %>
      <%= f.label :in_watchlist, "In Watchlist" %>
    </div>
    <div class="toggle-field">
      <%= f.check_box :consumed %>
      <%= f.label :consumed, "Read?" %>
    </div>
  </div>

  <div class="consumed-date-row" style="display: none;">
    <%= f.label :consumed_at, "Date Read" %>
    <%= f.date_field :consumed_at, value: Time.current.to_date %>
  </div>

  <div>
    <%= f.label :rating %>
    <%= f.select :rating, [["Unrated", ""], ["½ ★", "0.5"], ["★", "1.0"], ["★½", "1.5"], ["★★", "2.0"], ["★★½", "2.5"], ["★★★", "3.0"], ["★★★½", "3.5"], ["★★★★", "4.0"], ["★★★★½", "4.5"], ["★★★★★", "5.0"]] %>
  </div>

  <div>
    <%= f.label :review %>
    <%= f.text_area :review, rows: 4, placeholder: "Add a review..." %>
  </div>

  <div>
    <%= f.label :is_public, "Make Public?" %>
    <%= f.check_box :is_public %>
  </div>

  <%= f.submit "Create Comic" %>
<% end %>
