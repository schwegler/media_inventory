<div class="details-card" style="max-width: 700px;">
  <div class="media-item-header">
    <div class="media-item-cover">
      <% if @wrestling_event.thumbnail_url.present? %>
        <img src="<%= @wrestling_event.thumbnail_url %>" alt="<%= @wrestling_event.title %> Cover">
      <% else %>
        <span class="fallback-icon">🤼</span>
      <% end %>
    </div>
    
    <div class="media-item-details">
      <h1><%= @wrestling_event.title %></h1>
      <div class="media-sub-meta">
        <%= @wrestling_event.promotion %> &bull; <%= @wrestling_event.venue %>
        <br>
        <%= @wrestling_event.date&.strftime('%B %d, %Y') %>
        <span style="display:none;"><%= @wrestling_event.date %></span>
      </div>
      
      <div class="media-tracking-badges">
        <% if @wrestling_event.is_collected? %>
          <span class="tracking-badge badge-collected">📁 In Collection</span>
        <% end %>
        <% if @wrestling_event.in_watchlist? %>
          <span class="tracking-badge badge-watchlist">⏳ Watchlist</span>
        <% end %>
        <% if @wrestling_event.consumed? %>
          <span class="tracking-badge badge-consumed">
            ✓ Watched <%= "on #{@wrestling_event.consumed_at.strftime('%b %d, %Y')}" if @wrestling_event.consumed_at.present? %>
          </span>
        <% end %>
      </div>

      <% if @wrestling_event.rating.present? %>
        <div class="detail-row" style="border-bottom: none; padding: 0;">
          <strong>Rating:</strong>
          <span style="font-size: 1.2rem; color: #facc15;"><%= @wrestling_event.rating %> ★</span>
        </div>
      <% end %>
    </div>
  </div>

  <% if @wrestling_event.review.present? %>
    <div class="media-review-box">
      <h3>Review</h3>
      <p><%= simple_format(@wrestling_event.review) %></p>
    </div>
  <% end %>

  <div class="actions" style="margin-top: 2rem;">
    <%= link_to 'Back', wrestling_events_path, class: 'btn btn-secondary' %>
  </div>
</div>
