<div class="page-header">
  <h1><%= @user.name %>'s Collection</h1>
</div>

<% if @user.confirmed_at.nil? %>
  <p class="alert alert-warning">This user's collection is not public because their account is unconfirmed.</p>
<% else %>
  <div class="collection-section">
    <h2>Albums</h2>
    <ul class="media-grid">
      <% @albums.each do |album| %>
        <li class="media-card">
          <div class="card-icon">💿</div>
          <div class="card-content">
            <h3><%= link_to album.title, album %></h3>
            <span class="card-meta">Artist: <%= album.artist %></span>
          </div>
        </li>
      <% end %>
    </ul>
  </div>

  <div class="collection-section">
    <h2>Comics</h2>
    <ul class="media-grid">
      <% @comics.each do |comic| %>
        <li class="media-card">
          <div class="card-icon">📚</div>
          <div class="card-content">
            <h3><%= link_to comic.title, comic %></h3>
            <span class="card-meta">Writer: <%= comic.writer %></span>
          </div>
        </li>
      <% end %>
    </ul>
  </div>

  <div class="collection-section">
    <h2>Movies</h2>
    <ul class="media-grid">
      <% @movies.each do |movie| %>
        <li class="media-card">
          <div class="card-icon">🎬</div>
          <div class="card-content">
            <h3><%= link_to movie.title, movie %></h3>
            <span class="card-meta">Director: <%= movie.director %></span>
          </div>
        </li>
      <% end %>
    </ul>
  </div>

  <div class="collection-section">
    <h2>TV Shows</h2>
    <ul class="media-grid">
      <% @tv_shows.each do |tv_show| %>
        <li class="media-card">
          <div class="card-icon">📺</div>
          <div class="card-content">
            <h3><%= link_to tv_show.title, tv_show %></h3>
            <span class="card-meta">Network: <%= tv_show.network %></span>
          </div>
        </li>
      <% end %>
    </ul>
  </div>

  <div class="collection-section">
    <h2>Video Games</h2>
    <ul class="media-grid">
      <% @video_games.each do |game| %>
        <li class="media-card">
          <div class="card-icon">🎮</div>
          <div class="card-content">
            <h3><%= link_to game.title, game %></h3>
            <span class="card-meta">Developer: <%= game.developer %></span>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>
