<div class="page-header">
  <h1><%= @user.name %>'s Collection</h1>
</div>

<% if @user.confirmed_at.nil? %>
  <p class="alert alert-warning">This user's collection is not public because their account is unconfirmed.</p>
<% else %>
  <div class="collection-search-container">
    <form action="<%= collection_path(@user) %>" method="get" class="local-search-form" data-turbo-action="advance">
      <input type="text" name="q" class="local-search-input" placeholder="Search <%= @user.name %>'s collection..." value="<%= @query %>" autocomplete="off">
      <button type="submit" class="local-search-btn">
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
    </form>
  </div>

  <% has_any_items = @albums.any? || @comics.any? || @movies.any? || @tv_shows.any? || @video_games.any? %>
  
  <% if @query.present? && !has_any_items %>
    <div class="empty-state">
      <p>No items found matching "<%= @query %>" in <%= @user.name %>'s collection.</p>
    </div>
  <% else %>
    <% if @albums.any? %>
      <div class="collection-section">
        <h2>Albums</h2>
        <ul class="media-grid">
          <% @albums.each do |album| %>
            <li class="media-card">
              <div class="card-icon">💿</div>
              <div class="card-content">
                <h3><%= link_to album.title, album.item %></h3>
                <span class="card-meta">Artist: <%= album.artist %></span>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @comics.any? %>
      <div class="collection-section">
        <h2>Comics</h2>
        <ul class="media-grid">
          <% @comics.each do |comic| %>
            <li class="media-card">
              <div class="card-icon">📚</div>
              <div class="card-content">
                <h3><%= link_to comic.title, comic.item %></h3>
                <span class="card-meta">Writer: <%= comic.writer %></span>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @movies.any? %>
      <div class="collection-section">
        <h2>Movies</h2>
        <ul class="media-grid">
          <% @movies.each do |movie| %>
            <li class="media-card">
              <div class="card-icon">🎬</div>
              <div class="card-content">
                <h3><%= link_to movie.title, movie.item %></h3>
                <span class="card-meta">Director: <%= movie.director %></span>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @tv_shows.any? %>
      <div class="collection-section">
        <h2>TV Shows</h2>
        <ul class="media-grid">
          <% @tv_shows.each do |tv_show| %>
            <li class="media-card">
              <div class="card-icon">📺</div>
              <div class="card-content">
                <h3><%= link_to tv_show.title, tv_show.item %></h3>
                <span class="card-meta">Network: <%= tv_show.network %></span>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @video_games.any? %>
      <div class="collection-section">
        <h2>Video Games</h2>
        <ul class="media-grid">
          <% @video_games.each do |game| %>
            <li class="media-card">
              <div class="card-icon">🎮</div>
              <div class="card-content">
                <h3><%= link_to game.title, game.item %></h3>
                <span class="card-meta">Developer: <%= game.developer %></span>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  <% end %>
<% end %>
