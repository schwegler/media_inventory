<!DOCTYPE html>
<html lang="en" data-theme="<%= logged_in? ? current_user.theme : 'os' %>">
<head>
  <title><%= full_title(yield(:title)) %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">

  <!-- Open Graph -->
  <meta property="og:site_name" content="Trove">
  <meta property="og:title" content="<%= full_title(yield(:title)) %>">
  <meta property="og:description" content="<%= yield(:meta_description).presence || "Track and share your movies, albums, comics, and more on Trove." %>">
  <meta property="og:image" content="<%= yield(:meta_image).presence || request.base_url + "/favicon.svg" %>">
  <meta property="og:url" content="<%= request.original_url %>">
  <meta property="og:type" content="<%= yield(:og_type).presence || "website" %>">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= full_title(yield(:title)) %>">
  <meta name="twitter:description" content="<%= yield(:meta_description).presence || "Track and share your movies, albums, comics, and more on Trove." %>">
  <meta name="twitter:image" content="<%= yield(:meta_image).presence || request.base_url + "/favicon.svg" %>">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <%= stylesheet_link_tag "application", "data-turbo-track": Rails.env.production? ? "reload" : "" %>
  <%= javascript_importmap_tags %>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <% if hotwire_native_app? %>
    <meta name="turbo-visit-control" content="reload">
  <% end %>

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-PPD2TWSZBW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-PPD2TWSZBW');
  </script>
</head>
<body <% if hotwire_native_app? %>data-native="true"<% end %>>

  <% unless hotwire_native_app? %>
  <header class="app-header" data-controller="mobile-menu">
    <nav class="app-nav">
      <div class="nav-brand">
        <%= link_to root_path, class: 'brand-link' do %>
          <svg class="brand-logo" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 2L26 14L14 26L2 14L14 2Z" fill="url(#trove-gradient)" opacity="0.9"/>
            <path d="M14 6L22 14L14 22L6 14L14 6Z" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="0.5"/>
            <defs>
              <linearGradient id="trove-gradient" x1="2" y1="2" x2="26" y2="26">
                <stop offset="0%" stop-color="#ff6b35"/>
                <stop offset="100%" stop-color="#f7c948"/>
              </linearGradient>
            </defs>
          </svg>
          <span class="brand-text">Trove</span>
        <% end %>
      </div>

      <ul class="nav-links desktop-nav">
        <li><%= link_to "MOVIES", movies_path %></li>
        <li><%= link_to "ALBUMS", albums_path %></li>
        <li><%= link_to "COMICS", comics_path %></li>
        <li><%= link_to "TV SHOWS", tv_shows_path %></li>
        <li><%= link_to "GAMES", video_games_path %></li>
        <li><%= link_to "BOOKS", books_path %></li>
        <% if logged_in? %>
          <li><%= link_to "MEMBERS", users_path %></li>
        <% end %>
        <li class="nav-search-item">
          <form action="<%= search_path %>" method="get" class="global-search-form" data-controller="search" data-turbo-action="advance">
            <input type="text" name="q" class="global-search-input" data-search-target="input" placeholder="Search..." aria-label="Search" value="<%= params[:q] %>" autocomplete="off">
            <button type="submit" class="global-search-btn" aria-label="Submit search" data-action="click->search#toggle">
              <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
            </button>
          </form>
        </li>
      </ul>

      <div class="nav-user-section desktop-nav">
        <% if logged_in? %>
          <div class="nav-notifications" style="margin-right: 15px; display: flex; align-items: center;">
            <%= link_to notifications_path, class: "notification-bell", style: "position: relative; color: white; display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; background: rgba(255,255,255,0.1);" do %>
              <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
              </svg>
              <% unread_count = current_user.notifications.unread.count %>
              <% if unread_count > 0 %>
                <span style="position: absolute; top: -5px; right: -5px; background: #ef4444; color: white; font-size: 10px; font-weight: bold; width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; border-radius: 50%;"><%= unread_count > 9 ? '9+' : unread_count %></span>
              <% end %>
            <% end %>
          </div>

          <div class="nav-dropdown" data-controller="dropdown">
            <button class="nav-user-info sleek-btn usr-btn dropdown-toggle" type="button" data-action="click->dropdown#toggle" data-dropdown-target="button" aria-haspopup="true" aria-expanded="false">
              <%= user_avatar_tag(current_user, size: 24) %>
              <span class="nav-username"><%= current_user.name.upcase %></span>
              <svg class="dropdown-chevron" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            </button>
            <div class="dropdown-menu user-dropdown-menu" data-dropdown-target="menu" role="menu">
              <%= link_to "Profile", current_user, class: "dropdown-item", role: "menuitem" %>
              <%= link_to "Settings", settings_path, class: "dropdown-item", role: "menuitem" %>
              <div class="dropdown-divider"></div>
              <%= button_to "Sign Out", logout_path, method: :delete, class: "dropdown-item dropdown-logout-btn", role: "menuitem", form_class: "dropdown-logout-form" %>
            </div>
          </div>

          <div class="nav-dropdown" data-controller="dropdown" style="margin-left: 10px;">
            <button class="sleek-btn sleek-btn-success btn-log" type="button" data-action="click->dropdown#toggle" data-dropdown-target="button" aria-haspopup="true" aria-expanded="false" aria-label="Toggle log menu">
              <span>+ LOG</span>
              <svg class="dropdown-chevron" viewBox="0 0 20 20" fill="currentColor" style="width: 14px; height: 14px; margin-left: 4px;" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            </button>
            <div class="dropdown-menu" data-dropdown-target="menu" style="display: none;" role="menu">
              <%= link_to "🎬 Log Movie", new_movie_path, class: "dropdown-item", role: "menuitem", data: { turbo_frame: "modal" } %>
              <%= link_to "💿 Log Album", new_album_path, class: "dropdown-item", role: "menuitem", data: { turbo_frame: "modal" } %>
              <%= link_to "📚 Log Comic", new_comic_path, class: "dropdown-item", role: "menuitem", data: { turbo_frame: "modal" } %>
              <%= link_to "📺 Log TV Show", new_tv_show_path, class: "dropdown-item", role: "menuitem", data: { turbo_frame: "modal" } %>
              <%= link_to "🎮 Log Video Game", new_video_game_path, class: "dropdown-item", role: "menuitem", data: { turbo_frame: "modal" } %>
              <%= link_to "📘 Log Book", new_book_path, class: "dropdown-item", role: "menuitem", data: { turbo_frame: "modal" } %>
            </div>
          </div>
        <% else %>
          <%= link_to "LOG IN", login_path, class: 'sleek-btn sleek-btn-secondary' %>
        <% end %>
      </div>

      <button class="mobile-menu-btn" type="button" data-action="click->mobile-menu#toggle" aria-label="Toggle navigation">
        <svg class="menu-icon" data-mobile-menu-target="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg class="close-icon hidden" data-mobile-menu-target="closeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </nav>

    <div class="mobile-nav-panel" data-mobile-menu-target="menu">
      <div class="mobile-nav-search">
        <form action="<%= search_path %>" method="get" class="global-search-form" data-turbo-action="advance">
          <input type="text" name="q" class="global-search-input" placeholder="Search Trove..." aria-label="Search" value="<%= params[:q] %>" autocomplete="off">
          <button type="submit" class="global-search-btn" aria-label="Submit search">
            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
        </form>
      </div>
      <ul class="mobile-nav-links">
        <li><%= link_to "MOVIES", movies_path %></li>
        <li><%= link_to "ALBUMS", albums_path %></li>
        <li><%= link_to "COMICS", comics_path %></li>
        <li><%= link_to "TV SHOWS", tv_shows_path %></li>
        <li><%= link_to "GAMES", video_games_path %></li>
        <li><%= link_to "BOOKS", books_path %></li>
        <% if logged_in? %>
          <li><%= link_to "MEMBERS", users_path %></li>
        <% end %>
      </ul>
      <div class="mobile-nav-user-section">
        <% if logged_in? %>
          <div class="mobile-user-profile" style="position: relative; margin-bottom: 15px;">
            <%= user_avatar_tag(current_user, size: 48) %>
            <div class="mobile-user-info">
              <span class="nav-username"><%= current_user.name.upcase %></span>
              <div class="mobile-user-links">
                <%= link_to "Profile", current_user, class: "mobile-link" %>
                <%= link_to "Settings", settings_path, class: "mobile-link" %>
                <%= link_to notifications_path, class: "mobile-link" do %>
                  Notifications
                  <% unread_count = current_user.notifications.unread.count %>
                  <% if unread_count > 0 %>
                    <span style="background: #ef4444; color: white; font-size: 10px; font-weight: bold; padding: 2px 6px; border-radius: 10px; margin-left: 4px;"><%= unread_count %></span>
                  <% end %>
                <% end %>
                <%= button_to "Sign Out", logout_path, method: :delete, class: "mobile-link mobile-logout-btn", form_class: "dropdown-logout-form" %>
              </div>
            </div>
          </div>
          <div class="mobile-log-actions">
            <h4 class="mobile-log-header">LOG NEW ITEM</h4>
            <%= link_to "🎬 Log Movie", new_movie_path, class: "mobile-log-btn", data: { turbo_frame: "modal" } %>
            <%= link_to "💿 Log Album", new_album_path, class: "mobile-log-btn", data: { turbo_frame: "modal" } %>
            <%= link_to "📚 Log Comic", new_comic_path, class: "mobile-log-btn", data: { turbo_frame: "modal" } %>
            <%= link_to "📺 Log TV Show", new_tv_show_path, class: "mobile-log-btn", data: { turbo_frame: "modal" } %>
            <%= link_to "🎮 Log Video Game", new_video_game_path, class: "mobile-log-btn", data: { turbo_frame: "modal" } %>
            <%= link_to "📘 Log Book", new_book_path, class: "mobile-log-btn", data: { turbo_frame: "modal" } %>
          </div>
        <% else %>
          <div class="mobile-auth-actions">
            <%= link_to "LOG IN", login_path, class: 'btn btn-primary' %>
          </div>
        <% end %>
      </div>
    </div>
  </header>
  <% end %>

<main class="container">
  <div id="flash-messages">
    <% flash.each do |message_type, message| %>
      <div class="alert alert-<%= message_type %>" data-controller="flash" data-flash-dismiss-after-value="5000">
        <%= message %>
      </div>
    <% end %>
  </div>
  <%= yield %>
</main>

<footer class="app-footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-copyright">
        <p>&copy; 2025 Trove</p>
      </div>
      <div class="footer-attribution">
        <%= image_tag "tmdb_logo.svg", alt: "TMDB Logo", class: "tmdb-logo" %>
        <p class="attribution-text">This product uses the TMDB API but is not endorsed or certified by TMDB.</p>
      </div>
    </div>
  </div>
</footer>

  <% unless ['new', 'edit'].include?(action_name) %>
    <%= turbo_frame_tag "modal" %>
  <% end %>

</body>
</html>
