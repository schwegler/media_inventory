<!DOCTYPE html>
<html>
<head>
  <title><%= full_title(yield(:title)) %></title>
  <%= stylesheet_link_tag    "application", media: "all", "data-turbolinks-track" => true %>
  <%= javascript_include_tag "application", "data-turbolinks-track" => true, defer: true %>
  <%= csrf_meta_tags %>
</head>
<body>
  <div id="offline-banner" class="offline-banner">
    <span class="offline-indicator-dot"></span>
    <span id="offline-banner-text">Offline Mode | Submissions will be saved locally</span>
  </div>

  <header>
    <nav>
      <ul class="nav-links">
        <li><%= link_to "Comics", comics_path %></li>
        <li><%= link_to "TV Shows", tv_shows_path %></li>
        <li><%= link_to "Wrestling Events", wrestling_events_path %></li>
        <li><%= link_to "Movies", movies_path %></li>
        <li><%= link_to "Albums", albums_path %></li>
        <% if logged_in? %>
          <li><%= link_to "Users", users_path %></li>
          <li><%= link_to "Profile", current_user %></li>
          <li><%= link_to "Log out", logout_path, method: :delete %></li>
        <% else %>
          <li><%= link_to "Log in", login_path %></li>
        <% end %>
        <li id="nav-sync-item" style="display: none; align-self: center;">
          <span class="nav-sync-badge" id="nav-sync-badge" title="Click to view pending items">0 pending</span>
        </li>
      </ul>
    </nav>
  </header>

<main class="container">
  <% flash.each do |message_type, message| %>
    <div class="alert alert-<%= message_type %>"><%= message %></div>
  <% end %>
  <%= yield %>
</main>

<footer>
  <div class="container">
    <p>&copy; 2024 Sample App</p>
  </div>
</footer>

<div id="offline-toast-container" class="offline-toast-container"></div>

<div id="pending-sync-panel" class="pending-sync-panel">
  <div class="panel-header">
    <span>Pending Sync Items</span>
    <button class="close-btn" id="close-pending-panel">&times;</button>
  </div>
  <div class="panel-body" id="pending-sync-list">
    <div class="empty-state">No pending items to sync.</div>
  </div>
</div>

</body>
</html>
