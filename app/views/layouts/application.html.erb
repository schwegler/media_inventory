<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= full_title(yield(:title)) %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <% if hotwire_native_app? %>
    <meta name="turbo-visit-control" content="reload">
  <% end %>
</head>
<body <% if hotwire_native_app? %>data-native="true"<% end %>>

  <% unless hotwire_native_app? %>
  <header>
    <nav>
      <ul class="nav-links">
        <li><%= link_to "Comics", comics_path %></li>
        <li><%= link_to "TV Shows", tv_shows_path %></li>
        <li><%= link_to "Wrestling Events", wrestling_events_path %></li>
        <li><%= link_to "Movies", movies_path %></li>
        <li><%= link_to "Albums", albums_path %></li>
        <% if logged_in? %>
          <li><%= link_to "Users", users_path %></li>
          <li><%= link_to "Profile", current_user %></li>
          <li><%= button_to "Log out", logout_path, method: :delete, class: "nav-logout-btn" %></li>
        <% else %>
          <li><%= link_to "Log in", login_path %></li>
        <% end %>
      </ul>
    </nav>
  </header>
  <% end %>

<main class="container">
  <% flash.each do |message_type, message| %>
    <div class="alert alert-<%= message_type %>" data-controller="flash" data-flash-dismiss-after-value="5000">
      <%= message %>
    </div>
  <% end %>
  <%= yield %>
</main>

<footer>
  <div class="container">
    <p>&copy; 2024 Sample App</p>
  </div>
</footer>

<%= turbo_frame_tag "modal" %>

</body>
</html>
