<h1>Update your profile</h1>

<div class="row">
  <div class="col-md-6 col-md-offset-3">
    <%= form_with(model: @user, local: true, class: "standard-form") do |f| %>
      <%= render 'shared/error_messages', object: f.object %>

      <div class="form-group">
        <%= f.label :name %>
        <%= f.text_field :name, class: 'form-control', required: true %>
      </div>

      <div class="form-group" style="margin-top: 15px;">
        <%= f.label :email %>
        <%= f.email_field :email, class: 'form-control' %>
      </div>

      <div class="form-group" style="margin-top: 15px;">
        <%= f.label :avatar, "Profile Avatar" %>
        <%= f.file_field :avatar, class: 'form-control' %>
      </div>

      <div class="form-group" style="margin-top: 15px;">
        <%= f.label :header_banner, "Profile Banner" %>
        <%= f.file_field :header_banner, class: 'form-control' %>
      </div>

      <div class="form-group" style="margin-top: 15px;">
        <%= f.label :password, "New Password (optional)" %>
        <%= f.password_field :password, class: 'form-control', autocomplete: 'new-password' %>
      </div>

      <div class="form-group" style="margin-top: 15px;">
        <%= f.label :password_confirmation, "Confirmation" %>
        <%= f.password_field :password_confirmation, class: 'form-control', autocomplete: 'new-password' %>
      </div>

      <div style="border-top: 1px solid rgba(255,255,255,0.08); padding-top: 1.5rem; margin-top: 1.5rem; margin-bottom: 1.5rem;">
        <h3 style="font-size: 1.25rem; color: #fff; margin-bottom: 0.5rem;">🦋 Bluesky Integration</h3>
        
        <% if @user.bsky_access_token.present? || @user.bsky_password.present? %>
          <div style="padding: 1rem; background: rgba(2, 132, 199, 0.1); border-left: 4px solid #0284c7; margin-bottom: 1rem;">
            <p style="margin: 0;">✅ Connected as <strong><%= @user.bsky_handle %></strong></p>
          </div>
          
          <div style="margin-top: 15px; display: flex; gap: 20px; flex-wrap: wrap;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <%= f.check_box :bsky_post_activity %>
              <%= f.label :bsky_post_activity, "Auto-post new additions", style: "margin-bottom: 0;" %>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
              <%= f.check_box :bsky_post_reviews %>
              <%= f.label :bsky_post_reviews, "Auto-post reviews", style: "margin-bottom: 0;" %>
            </div>
          </div>

          <div class="form-group" style="margin-top: 15px;">
            <%= f.label :bsky_message_activity_template, "Activity Template" %>
            <%= f.text_field :bsky_message_activity_template, class: 'form-control', placeholder: 'Just added [title] to my library! #mediatracker' %>
            <small style="color: #64748b; font-size: 0.75rem;">Placeholders: [title], [type]</small>
          </div>

          <div class="form-group" style="margin-top: 15px;">
            <%= f.label :bsky_message_review_template, "Review Template" %>
            <%= f.text_field :bsky_message_review_template, class: 'form-control', placeholder: 'My review of [title]: [review] - [rating]★ #mediatracker' %>
            <small style="color: #64748b; font-size: 0.75rem;">Placeholders: [title], [review], [rating]</small>
          </div>
        <% else %>
          <p style="font-size: 0.8rem; color: #94a3b8; margin-bottom: 1rem; line-height: 1.4;">
            Connect your Bluesky (bsky.app) account to automatically post updates and reviews.
          </p>
          <div style="margin-bottom: 15px;">
            <%= f.label :bsky_handle, "Bluesky Handle (App Password)" %>
            <%= f.text_field :bsky_handle, class: 'form-control', placeholder: 'e.g. alice.bsky.social' %>
          </div>
          <div style="margin-bottom: 15px;">
            <%= f.label :bsky_password, "Bluesky App Password" %>
            <%= f.password_field :bsky_password, class: 'form-control', placeholder: 'xxxx-xxxx-xxxx-xxxx' %>
          </div>
          <p style="text-align: center; margin: 10px 0; color: #94a3b8;">OR</p>
          <%= button_to "Connect Bluesky via OAuth", "/auth/atproto", method: :post, data: { turbo: false }, class: "sleek-btn sleek-btn-primary", style: "width: 100%; background: #0284c7; border-color: #0ea5e9;" %>
        <% end %>
      </div>

      <div style="border-top: 1px solid rgba(255,255,255,0.08); padding-top: 1.5rem; margin-top: 1.5rem; margin-bottom: 1.5rem;">
        <h3 style="font-size: 1.25rem; color: #fff; margin-bottom: 0.5rem;">🐘 Mastodon Integration</h3>
        
        <% if @user.mastodon_access_token.present? %>
          <div style="padding: 1rem; background: rgba(86, 58, 204, 0.1); border-left: 4px solid #563acc; margin-bottom: 1rem;">
            <p style="margin: 0;">✅ Connected to <strong><%= @user.mastodon_server %></strong></p>
          </div>
          
          <div style="margin-top: 15px; display: flex; gap: 20px; flex-wrap: wrap;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <%= f.check_box :mastodon_post_activity %>
              <%= f.label :mastodon_post_activity, "Auto-post new additions", style: "margin-bottom: 0;" %>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
              <%= f.check_box :mastodon_post_reviews %>
              <%= f.label :mastodon_post_reviews, "Auto-post reviews", style: "margin-bottom: 0;" %>
            </div>
          </div>

          <div class="form-group" style="margin-top: 15px;">
            <%= f.label :mastodon_message_activity_template, "Activity Template" %>
            <%= f.text_field :mastodon_message_activity_template, class: 'form-control', placeholder: 'Just added [title] to my library! #mediatracker' %>
            <small style="color: #64748b; font-size: 0.75rem;">Placeholders: [title], [type]</small>
          </div>

          <div class="form-group" style="margin-top: 15px;">
            <%= f.label :mastodon_message_review_template, "Review Template" %>
            <%= f.text_field :mastodon_message_review_template, class: 'form-control', placeholder: 'My review of [title]: [review] - [rating]★ #mediatracker' %>
            <small style="color: #64748b; font-size: 0.75rem;">Placeholders: [title], [review], [rating]</small>
          </div>
        <% else %>
          <p style="font-size: 0.8rem; color: #94a3b8; margin-bottom: 1rem; line-height: 1.4;">
            Connect your Mastodon account to automatically post updates and reviews.
          </p>
          <div style="margin-bottom: 15px;">
            <%= label_tag :mastodon_server, "Mastodon Server URL" %>
            <%= text_field_tag :mastodon_server, nil, class: 'form-control', placeholder: 'e.g. mastodon.social', id: 'mastodon_server_input' %>
          </div>
          <button type="button" class="sleek-btn sleek-btn-primary" style="background: #563acc; border-color: #7c3aed;" onclick="connectMastodon()">Connect Mastodon</button>
          
          <script>
            function connectMastodon() {
              const server = document.getElementById('mastodon_server_input').value;
              if (!server) {
                alert('Please enter a Mastodon server URL');
                return;
              }
              const form = document.createElement('form');
              form.method = 'POST';
              form.action = '/auth/mastodon';
              
              const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
              const csrfInput = document.createElement('input');
              csrfInput.type = 'hidden';
              csrfInput.name = 'authenticity_token';
              csrfInput.value = csrfToken;
              form.appendChild(csrfInput);

              const serverInput = document.createElement('input');
              serverInput.type = 'hidden';
              serverInput.name = 'mastodon_server';
              serverInput.value = server;
              form.appendChild(serverInput);
              
              document.body.appendChild(form);
              form.submit();
            }
          </script>
        <% end %>
      </div>

      <%= f.submit "Save changes", class: "sleek-btn sleek-btn-primary", style: "margin-top: 20px; width: 100%;" %>
    <% end %>
  </div>
</div>
