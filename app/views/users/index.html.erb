<div class="page-header">
  <h1>All Users</h1>
</div>

<turbo-frame id="users_list">
  <div class="pagination-wrapper">
    <%= paginate @users %>
  </div>

  <ul class="media-grid">
    <% @users.each do |user| %>
      <li class="media-card user-card">
        <div class="card-icon" style="background: none; border: none;">
          <%= user_avatar_tag(user, size: 44) %>
        </div>
        <div class="card-content">
          <h3><%= link_to user.name, user, data: { turbo_frame: "_top" } %></h3>
          <span class="card-meta"><%= user.display_handle %></span>
        </div>
        <% if current_user.admin? && !current_user?(user) %>
          <div class="card-actions">
            <%= button_to "Delete", user, method: :delete,
                                      data: { turbo_confirm: "Are you sure?", turbo_frame: "_top" },
                                      class: "btn btn-danger btn-sm" %>
          </div>
        <% end %>
      </li>
    <% end %>
  </ul>

  <div class="pagination-wrapper">
    <%= paginate @users %>
  </div>
</turbo-frame>
