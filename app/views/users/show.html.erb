<div class="profile-page">
  <div class="profile-header">
    <div class="header-banner">
      <% if @user.header_banner.attached? %>
        <%= image_tag @user.header_banner, class: "banner-img" %>
      <% else %>
        <div class="banner-placeholder"></div>
      <% end %>
    </div>

    <div class="profile-info-bar">
      <div class="avatar-container">
        <%= user_avatar_tag(@user, size: 120) %>
      </div>

      <div class="profile-main-meta">
        <h1 class="profile-display-name"><%= @user.name %></h1>
        <p class="profile-handle"><%= @user.display_handle %></p>
      </div>

      <div class="profile-stats">
        <div class="stat-item">
          <span class="stat-count"><%= @user.library_items.where(is_collected: true).count %></span>
          <span class="stat-label">Collection</span>
        </div>
        <div class="stat-item">
          <span class="stat-count"><%= @user.library_items.where(in_backlog: true).count %></span>
          <span class="stat-label">Backlog</span>
        </div>
        <%= link_to following_user_path(@user), class: "stat-item" do %>
          <span class="stat-count"><%= @user.following.count %></span>
          <span class="stat-label">Following</span>
        <% end %>
        <%= link_to followers_user_path(@user), class: "stat-item" do %>
          <span class="stat-count"><%= @user.followers.count %></span>
          <span class="stat-label">Followers</span>
        <% end %>
      </div>

      <div class="profile-actions">
        <% if current_user?(@user) %>
          <%= link_to 'Edit Profile', settings_path, class: 'btn btn-outline' %>
        <% elsif logged_in? %>
          <%= render 'follow_form', user: @user %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="profile-body">
    <aside class="profile-sidebar">
      <% if @user.bio.present? %>
        <div class="bio-section card">
          <h3>About</h3>
          <p><%= @user.bio %></p>
        </div>
      <% end %>

      <% if @user.birthday.present? %>
        <div class="info-section card">
          <div class="info-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path></svg>
            <span>Born <%= @user.birthday.strftime("%B %d, %Y") %></span>
          </div>
        </div>
      <% end %>
    </aside>

    <main class="profile-content" data-controller="tabs">
      <nav class="profile-tabs">
        <button class="tab-btn active" data-action="click->tabs#switch" data-tabs-target="tab" data-tab-name="posts">Activity</button>
        <button class="tab-btn" data-action="click->tabs#switch" data-tabs-target="tab" data-tab-name="collection">Collection</button>
        <button class="tab-btn" data-action="click->tabs#switch" data-tabs-target="tab" data-tab-name="backlog">Backlog</button>
        <button class="tab-btn" data-action="click->tabs#switch" data-tabs-target="tab" data-tab-name="likes">Likes</button>
      </nav>

      <div class="tab-content" data-tabs-target="content" data-tab-name="posts">
        <div class="activities-feed">
          <% if @activities.any? %>
            <%= render @activities %>
          <% else %>
            <p class="empty-state">No recent activity.</p>
          <% end %>
        </div>
      </div>

      <div class="tab-content hidden" data-tabs-target="content" data-tab-name="collection">
        <div class="media-filter-bar">
          <form action="<%= user_path(@user) %>" method="get" data-turbo-frame="collection_frame">
            <input type="hidden" name="tab" value="collection">
            <select name="type" onchange="this.form.submit()" class="filter-select">
              <option value="">All Media</option>
              <option value="Movie" <%= 'selected' if params[:type] == 'Movie' %>>Movies</option>
              <option value="TvShow" <%= 'selected' if params[:type] == 'TvShow' %>>TV Shows</option>
              <option value="Album" <%= 'selected' if params[:type] == 'Album' %>>Albums</option>
              <option value="Comic" <%= 'selected' if params[:type] == 'Comic' %>>Comics</option>
              <option value="VideoGame" <%= 'selected' if params[:type] == 'VideoGame' %>>Games</option>
            </select>
          </form>
        </div>
        <%= turbo_frame_tag "collection_frame" do %>
          <div class="media-grid">
             <% collection_items = @user.library_items.where(is_collected: true) %>
             <% collection_items = collection_items.where(item_type: params[:type]) if params[:type].present? %>
             <% collection_items = collection_items.order(created_at: :desc) %>
             
             <% if collection_items.any? %>
               <div class="grid-layout poster-grid">
                 <% collection_items.each do |lib_item| %>
                   <% item = lib_item.item %>
                   <div class="media-card poster-card">
                     <% if item.respond_to?(:thumbnail_url) && item.thumbnail_url.present? %>
                       <%= image_tag item.thumbnail_url, class: "media-thumb poster-img" %>
                     <% else %>
                       <div class="poster-placeholder"><%= item.title %></div>
                     <% end %>
                     <div class="poster-overlay">
                       <span class="media-title"><%= item.title %></span>
                       <% if lib_item.rating.present? %>
                         <span class="media-rating"><%= lib_item.rating %></span>
                       <% end %>
                     </div>
                   </div>
                 <% end %>
               </div>
             <% else %>
               <p class="empty-state">No items in collection.</p>
             <% end %>
          </div>
        <% end %>
      </div>

      <div class="tab-content hidden" data-tabs-target="content" data-tab-name="backlog">
        <div class="media-grid">
           <% backlog_items = @user.library_items.where(in_backlog: true).order(created_at: :desc) %>
           <% if backlog_items.any? %>
             <div class="grid-layout poster-grid">
               <% backlog_items.each do |lib_item| %>
                 <% item = lib_item.item %>
                 <div class="media-card poster-card">
                   <% if item.respond_to?(:thumbnail_url) && item.thumbnail_url.present? %>
                     <%= image_tag item.thumbnail_url, class: "media-thumb poster-img" %>
                   <% else %>
                     <div class="poster-placeholder"><%= item.title %></div>
                   <% end %>
                   <div class="poster-overlay">
                     <span class="media-title"><%= item.title %></span>
                   </div>
                 </div>
               <% end %>
             </div>
           <% else %>
             <p class="empty-state">Backlog is empty.</p>
           <% end %>
        </div>
      </div>

      <div class="tab-content hidden" data-tabs-target="content" data-tab-name="likes">
        <div class="likes-feed">
          <% if @likes.any? %>
            <% @likes.each do |like| %>
              <div class="like-item card">
                <span>Liked a <%= like.likeable_type.titleize %></span>
                <% if like.likeable.respond_to?(:title) %>
                  <strong><%= like.likeable.title %></strong>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <p class="empty-state">No likes yet.</p>
          <% end %>
        </div>
      </div>
    </main>
  </div>
</div>
