<div class="profile-page">
  <div class="profile-header">
    <div class="header-banner">
      <% if @user.header_banner.attached? %>
        <%= image_tag @user.header_banner, class: "banner-img" %>
      <% else %>
        <div class="banner-placeholder"></div>
      <% end %>
    </div>

    <div class="profile-info-bar">
      <div class="avatar-container">
        <%= user_avatar_tag(@user, size: 120) %>
      </div>

      <div class="profile-main-meta">
        <h1 class="profile-display-name"><%= @user.name %></h1>
        <p class="profile-handle"><%= @user.display_handle %></p>
      </div>

      <div class="profile-stats">
        <div class="stat-item">
          <span class="stat-count"><%= @collection_items.count %></span>
          <span class="stat-label">Collection</span>
        </div>
        <div class="stat-item">
          <span class="stat-count"><%= @backlog_items.count %></span>
          <span class="stat-label">Backlog</span>
        </div>
        <%= link_to following_user_path(@user), class: "stat-item" do %>
          <span class="stat-count"><%= @user.following.count %></span>
          <span class="stat-label">Following</span>
        <% end %>
        <%= link_to followers_user_path(@user), class: "stat-item" do %>
          <span class="stat-count"><%= @user.followers.count %></span>
          <span class="stat-label">Followers</span>
        <% end %>
      </div>

      <div class="profile-actions">
        <% if current_user?(@user) %>
          <%= link_to 'Edit Profile', settings_path, class: 'btn sleek-btn usr-btn' %>
        <% elsif logged_in? %>
          <%= render 'follow_form', user: @user %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="profile-body">
    <aside class="profile-sidebar">
      <% if @user.bio.present? %>
        <div class="bio-section card">
          <h3>About</h3>
          <p><%= @user.bio %></p>
        </div>
      <% end %>

      <% if @user.birthday.present? %>
        <div class="info-section card">
          <div class="info-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path></svg>
            <span>Born <%= @user.birthday.strftime("%B %d, %Y") %></span>
          </div>
        </div>
      <% end %>
    </aside>

    <main class="profile-content" data-controller="tabs">
      <nav class="profile-tabs">
        <button class="tab-btn active" data-action="click->tabs#switch" data-tabs-target="tab" data-tab-name="posts">Activity</button>
        <button class="tab-btn" data-action="click->tabs#switch" data-tabs-target="tab" data-tab-name="collection">Collection</button>
        <button class="tab-btn" data-action="click->tabs#switch" data-tabs-target="tab" data-tab-name="backlog">Backlog</button>
        <button class="tab-btn" data-action="click->tabs#switch" data-tabs-target="tab" data-tab-name="likes">Likes</button>
      </nav>

      <div class="tab-content" data-tabs-target="content" data-tab-name="posts">
        <% if current_user?(@user) %>
          <div class="post-creation-box card" style="margin-bottom: 20px; padding: 15px; background: rgba(255,255,255,0.02); border-radius: 8px;">
            <%= form_with model: Post.new, url: posts_path, local: true do |f| %>
              <%= f.text_area :content, placeholder: "What's on your mind?", required: true, class: "post-input" %>
              <div style="display: flex; justify-content: flex-end;">
                <%= f.submit "Post", class: "btn btn-primary" %>
              </div>
            <% end %>
          </div>
        <% end %>

        <div class="activities-feed">
          <% items = (@activities + @user.posts).sort_by(&:created_at).reverse %>
          <% if items.any? %>
            <% items.each do |item| %>
              <% if item.is_a?(Post) %>
                <div class="post-card card" style="margin-bottom: 15px; padding: 15px; border-radius: 8px; cursor: pointer;" onclick="window.location='<%= post_path(item) %>'">
                  <div style="display: flex; gap: 10px; margin-bottom: 10px;">
                    <%= link_to user_path(item.user), style: "z-index: 1;" do %>
                      <%= user_avatar_tag(item.user, size: 40) %>
                    <% end %>
                    <div style="display: flex; flex-direction: column; justify-content: center;">
                      <div style="display: flex; align-items: baseline; gap: 5px;">
                        <%= link_to user_path(item.user), style: "text-decoration: none; color: inherit; z-index: 1;" do %>
                          <strong style="font-size: 1rem;"><%= item.user.name.presence || item.user.display_handle %></strong>
                        <% end %>
                        <span style="color: #94a3b8; font-size: 0.85rem;"><%= item.user.display_handle %></span>
                        <span style="color: #94a3b8; font-size: 0.85rem;">· <%= time_ago_in_words(item.created_at) %></span>
                      </div>
                    </div>
                  </div>
                  
                  <div class="post-content" style="margin-bottom: 15px; font-size: 1rem; line-height: 1.4;">
                    <%= format_content_with_mentions(item.content) %>
                  </div>
                  
                  <div class="post-actions tweet-actions" style="gap: 20px; color: #94a3b8;">
                    <div class="btn-reply btn-unstyled tweet-action-btn" onclick="event.stopPropagation();">
                      <%= link_to post_path(item), style: "color: inherit; text-decoration: none; display: flex; align-items: center; gap: 6px;" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='#818cf8';" onmouseout="this.style.color='currentColor';">
                          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
                        </svg>
                        <span style="font-size: 0.9rem;"><%= item.comments.count > 0 ? item.comments.count : '' %></span>
                      <% end %>
                    </div>

                    <div style="display: flex; align-items: center; gap: 6px; z-index: 1;" onclick="event.stopPropagation();">
                      <%= render 'likes/like_button', item: item, tweet_style: true %>
                    </div>
                  </div>
                </div>
              <% else %>
                <%= render item %>
              <% end %>
            <% end %>
          <% else %>
            <p class="empty-state">No recent activity.</p>
          <% end %>
        </div>
      </div>

      <div class="tab-content hidden" data-tabs-target="content" data-tab-name="collection">
        <%= turbo_frame_tag "collection_frame" do %>
          <div class="media-filter-bar" style="margin-bottom: 20px;">
            <form action="<%= user_path(@user) %>" method="get" data-controller="filter" data-turbo-frame="collection_frame" data-turbo-action="advance">
              <input type="hidden" name="tab" value="collection">
              <select name="type" data-action="change->filter#submit" class="filter-select">
                <option value="">All Media</option>
                <option value="Movie" <%= 'selected' if params[:type] == 'Movie' %>>Movies</option>
                <option value="TvShow" <%= 'selected' if params[:type] == 'TvShow' %>>TV Shows</option>
                <option value="Album" <%= 'selected' if params[:type] == 'Album' %>>Albums</option>
                <option value="Comic" <%= 'selected' if params[:type] == 'Comic' %>>Comics</option>
                <option value="Book" <%= 'selected' if params[:type] == 'Book' %>>Books</option>
                <option value="VideoGame" <%= 'selected' if params[:type] == 'VideoGame' %>>Games</option>
              </select>
            </form>
          </div>
          <div class="media-grid">
             <% if @collection_items.any? %>
                 <% @collection_items.each do |lib_item| %>
                   <% item = lib_item.item %>
                   <% next unless item %>
                   <%= render partial: 'shared/media_card', locals: { media_item: item } %>
                 <% end %>
             <% else %>
               <p class="empty-state">No items in collection.</p>
             <% end %>
          </div>
        <% end %>
      </div>

      <div class="tab-content hidden" data-tabs-target="content" data-tab-name="backlog">
        <div class="media-grid">
           <% if @backlog_items.any? %>
               <% @backlog_items.each do |lib_item| %>
                 <% item = lib_item.item %>
                 <% next unless item %>
                 <%= render partial: 'shared/media_card', locals: { media_item: item } %>
               <% end %>
           <% else %>
             <p class="empty-state">Backlog is empty.</p>
           <% end %>
        </div>
      </div>

      <div class="tab-content hidden" data-tabs-target="content" data-tab-name="likes">
        <div class="likes-feed">
          <% if @likes.any? %>
            <% @likes.each do |like| %>
              <div class="like-item card">
                <span>Liked a <%= like.likeable_type.titleize %></span>
                <% if like.likeable.respond_to?(:title) %>
                  <strong><%= like.likeable.title %></strong>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <p class="empty-state">No likes yet.</p>
          <% end %>
        </div>
      </div>
    </main>
  </div>
</div>
