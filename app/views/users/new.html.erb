<h1>Sign up</h1>

<div class="row">
  <div class="col-md-6 col-md-offset-3">
    <%= form_with(model: @user, local: true, class: "standard-form") do |f| %>
      <%= render 'shared/error_messages', object: f.object if lookup_context.exists?('shared/_error_messages') %>

      <div class="form-group">
        <%= f.label :name %>
        <%= f.text_field :name, class: 'form-control', required: true %>
      </div>

      <div class="form-group" style="margin-top: 15px;">
        <%= f.label :email %>
        <%= f.email_field :email, class: 'form-control', required: true %>
      </div>

      <div class="form-group" style="margin-top: 15px;">
        <%= f.label :password %>
        <%= f.password_field :password, class: 'form-control', required: true %>
      </div>

      <div class="form-group" style="margin-top: 15px;">
        <%= f.label :password_confirmation, "Confirmation" %>
        <%= f.password_field :password_confirmation, class: 'form-control', required: true %>
      </div>
      <div style="margin-top: 15px;">
        <%= f.submit "Sign up", class: "sleek-btn sleek-btn-primary", style: "width: 100%; justify-content: center;" %>
      </div>
    <% end %>

    <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.08); margin: 2rem 0;">

    <h2 style="font-size: 1.25rem; text-align: center; margin-bottom: 1.5rem;">🦋 Sign up with Bluesky</h2>
    <div style="text-align: center;">
      <%= button_to "Sign up via Bluesky", "/auth/atproto", method: :post, data: { turbo: false }, class: "btn btn-secondary", style: "margin-top: 20px; width: 100%; background: #0284c7; border: none; color: #fff;" %>
    </div>
  </div>

  <div class="auth-section" style="flex: 1; padding: 2rem; background: #2d3748; border-radius: 8px;">
    <h2 style="font-size: 1.25rem; text-align: center; margin-bottom: 1.5rem;">🐘 Sign up with Mastodon</h2>
    <div style="text-align: center;">
      <%= form_tag "/auth/mastodon", method: :post, data: { turbo: false } do %>
        <div class="form-group" style="margin-bottom: 1.5rem;">
          <%= label_tag :mastodon_server, "Mastodon Server URL" %>
          <%= text_field_tag :mastodon_server, nil, class: 'form-control', placeholder: 'e.g. mastodon.social', required: true %>
        </div>
        <%= submit_tag "Sign up via Mastodon", class: "btn btn-secondary", style: "width: 100%; background: #563acc; border: none; color: #fff;" %>
      <% end %>
    </div>
  </div>
</div>
