<div class="page-header">
  <h1>TV Shows</h1>
  <% if logged_in? %>
    <%= link_to 'New TV Show', new_tv_show_path, class: 'sleek-btn sleek-btn-primary' %>
  <% end %>
</div>

<turbo-frame id="items_list">
  <div class="media-grid-2026">
  <% @tv_shows.each do |tv_show| %>
    <%= render partial: 'shared/media_card', locals: { media_item: tv_show } %>
  <% end %>
</div>

  <div class="pagination-wrapper">
    <%= paginate @tv_shows %>
  </div>
</turbo-frame>
