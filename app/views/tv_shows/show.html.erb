<%
  backdrop_url = nil
  if @tv_show.cover_image.attached?
    backdrop_url = url_for(@tv_show.cover_image)
  elsif @tv_show.thumbnail_url.present?
    backdrop_url = @tv_show.thumbnail_url
  end
%>

<div class="show-hero">
  <% if backdrop_url %>
    <div class="show-hero-backdrop" style="background-image: url('<%= backdrop_url %>');"></div>
  <% end %>
  <div class="show-hero-gradient"></div>
</div>

<div class="show-container container">
  <!-- Left Column: Poster and Quick Actions -->
  <div class="show-left">
    <div class="show-poster-card">
      <div class="show-poster">
        <% if @tv_show.cover_image.attached? %>
          <%= image_tag @tv_show.cover_image, alt: "#{@tv_show.title} Cover" %>
        <% elsif @tv_show.thumbnail_url.present? %>
          <img src="<%= @tv_show.thumbnail_url %>" alt="<%= @tv_show.title %> Cover">
        <% else %>
          <div class="poster-fallback"><span class="fallback-emoji">📺</span></div>
        <% end %>
      </div>
      
      <div class="poster-stats">
        <% stats = community_stats_for(@tv_show) %>
        <span class="stat-item" title="Watchers"><span class="stat-icon">👁</span> <%= stats[:watchers].size %></span>
        <span class="stat-item" title="Collectors"><span class="stat-icon">📁</span> <%= stats[:collectors].size %></span>
        <span class="stat-item" title="Likes"><span class="stat-icon">♥</span> <%= @tv_show.likes.count %></span>
      </div>
    </div>

  </div>

  <!-- Right Column: Title, Metadata, Reviews -->
  <div class="show-right">
    <div class="show-header-details">
      <h1 class="show-title"><%= @tv_show.title %></h1>
      <p class="show-meta-subtitle">
        on <span class="meta-highlight"><%= @tv_show.network || 'Unknown Network' %></span> &bull; Season <%= @tv_show.season %> Episode <%= @tv_show.episode %>
      </p>
      
      <% if @tv_show.rating.present? %>
        <div class="show-rating"><%= render_stars(@tv_show.rating) %></div>
      <% end %>
    </div>

    <%= render 'shared/media_actions_and_stream', item: @tv_show %>

    <% if @tv_show.review.present? %>
      <div class="show-review">
        <h3>My Review</h3>
        <blockquote><%= simple_format(@tv_show.review) %></blockquote>
      </div>
    <% end %>

    <div class="show-community">
      <h2>Community</h2>

      <div class="show-stats-bar">
        <div class="show-stat">
          <div class="show-stat-value"><%= stats[:avg_rating] ? "#{stats[:avg_rating]} ★" : "—" %></div>
          <div class="show-stat-label">Average Rating</div>
        </div>
        <div class="show-stat">
          <div class="show-stat-value"><%= stats[:watchers].size %></div>
          <div class="show-stat-label">Watchers</div>
        </div>
        <div class="show-stat">
          <div class="show-stat-value"><%= stats[:collectors].size %></div>
          <div class="show-stat-label">Collectors</div>
        </div>
      </div>

      <% if stats[:reviews].any? %>
        <h3>Community Reviews</h3>
        <div class="show-reviews-list">
          <% stats[:reviews].each do |matching_item| %>
            <div class="show-review-card">
              <div class="review-header">
                <%= user_avatar_tag(matching_item.user, size: 28) %>
                <div class="review-meta-info">
                  <span class="review-user"><%= matching_item.user.name.presence || matching_item.user.display_handle %></span>
                  <% if matching_item.rating.present? %>
                    <span class="review-rating"><%= render_stars(matching_item.rating) %></span>
                  <% end %>
                </div>
              </div>
              <div class="review-content"><%= simple_format(matching_item.review) %></div>
              
              <div class="review-actions-row">
                <%= render 'likes/like_button', item: matching_item %>
              </div>

              <%= render 'shared/comments_box', matching_item: matching_item %>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if stats[:watchers].any? %>
        <h3>Watchers</h3>
        <div class="show-members-list">
          <% stats[:watchers].each do |user| %>
            <span class="show-member-tag"><%= user_avatar_tag(user, size: 20) %> <%= user.name.presence || user.display_handle %></span>
          <% end %>
        </div>
      <% end %>

      <% if stats[:collectors].any? %>
        <h3>Collectors</h3>
        <div class="show-members-list">
          <% stats[:collectors].each do |user| %>
            <span class="show-member-tag"><%= user_avatar_tag(user, size: 20) %> <%= user.name.presence || user.display_handle %></span>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="show-actions">
      <%= link_to '← Back to TV Shows', tv_shows_path, class: 'btn btn-secondary' %>
    </div>
  </div>
</div>
