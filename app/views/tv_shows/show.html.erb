<div class="details-card" style="max-width: 700px;">
  <div class="media-item-header">
    <div class="media-item-cover">
      <% if @tv_show.cover_image.attached? %>
        <%= image_tag @tv_show.cover_image, alt: "#{@tv_show.title} Cover" %>
      <% elsif @tv_show.thumbnail_url.present? %>
        <img src="<%= @tv_show.thumbnail_url %>" alt="<%= @tv_show.title %> Cover">
      <% else %>
        <span class="fallback-icon">📺</span>
      <% end %>
    </div>
    
    <div class="media-item-details">
      <h1><%= @tv_show.title %></h1>
      <div class="media-sub-meta">Season <%= @tv_show.season %> Episode <%= @tv_show.episode %> &bull; <%= @tv_show.network || 'Unknown Network' %></div>
      
      <div style="margin-top: 10px;">
        <% if logged_in? && (@tv_show.user == current_user || current_user.admin?) %>
          <%= link_to 'Edit TV Show', edit_tv_show_path(@tv_show), class: 'btn btn-sm btn-secondary', style: "font-size: 0.8em;" %>
        <% end %>
      </div>

      <div class="media-tracking-badges">
        <span class="tracking-badge badge-justwatch" style="background-color: #facc15; color: #000;">
          <%= link_to 'Search on JustWatch', "https://www.justwatch.com/us/search?q=#{u(@tv_show.title)}", target: '_blank', style: "color: inherit; text-decoration: none; font-weight: bold;" %>
        </span>
        <% if @tv_show.is_collected? %>
          <span class="tracking-badge badge-collected">📁 In Collection</span>
        <% end %>
        <% if @tv_show.in_watchlist? %>
          <span class="tracking-badge badge-watchlist">⏳ Watchlist</span>
        <% end %>
        <% if @tv_show.consumed? %>
          <span class="tracking-badge badge-consumed">
            ✓ Watched <%= "on #{@tv_show.consumed_at.strftime('%b %d, %Y')}" if @tv_show.consumed_at.present? %>
          </span>
        <% end %>
      </div>

      <% if @tv_show.rating.present? %>
        <div class="detail-row" style="border-bottom: none; padding: 0;">
          <strong>Rating:</strong>
          <span style="font-size: 1.2rem; color: #facc15;"><%= @tv_show.rating %> ★</span>
        </div>
      <% end %>
    </div>
  </div>

  <% if @tv_show.review.present? %>
    <div class="media-review-box">
      <h3>Review</h3>
      <p><%= simple_format(@tv_show.review) %></p>
    </div>
  <% end %>

  <% stats = community_stats_for(@tv_show) %>
  <div class="community-section">
    <h2>Community Activity</h2>
    
    <div class="community-stats">
      <div class="stat-box">
        <div class="stat-label">Average Rating</div>
        <div class="stat-value">
          <% if stats[:avg_rating] %>
            <%= stats[:avg_rating] %> ★
          <% else %>
            —
          <% end %>
        </div>
      </div>
      <div class="stat-box">
        <div class="stat-label">Watchers</div>
        <div class="stat-value"><%= stats[:watchers].size %></div>
      </div>
      <div class="stat-box">
        <div class="stat-label">Collectors</div>
        <div class="stat-value"><%= stats[:collectors].size %></div>
      </div>
    </div>

    <% if stats[:reviews].any? %>
      <h3 style="font-size: 1.2rem; margin-bottom: 1rem;">Community Reviews</h3>
      <div class="community-reviews-list">
        <% stats[:reviews].each do |matching_item| %>
          <div class="community-review-card">
            <div class="review-header">
              <span class="review-user"><%= matching_item.user.name.presence || matching_item.user.email %></span>
              <% if matching_item.rating.present? %>
                <span class="review-rating"><%= matching_item.rating %> ★</span>
              <% end %>
            </div>
            <div class="review-content"><%= simple_format(matching_item.review) %></div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if stats[:watchers].any? %>
      <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem; margin-top: 1.5rem;">Watchers</h3>
      <div class="community-members-list" style="margin-bottom: 1.5rem;">
        <% stats[:watchers].each do |user| %>
          <span class="member-tag">👤 <%= user.name.presence || user.email %></span>
        <% end %>
      </div>
    <% end %>

    <% if stats[:collectors].any? %>
      <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Collectors</h3>
      <div class="community-members-list">
        <% stats[:collectors].each do |user| %>
          <span class="member-tag">📁 <%= user.name.presence || user.email %></span>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="actions" style="margin-top: 2rem;">
    <%= link_to 'Back', tv_shows_path, class: 'btn btn-secondary' %>
  </div>
</div>
