<h1>New Album</h1>
<div data-controller="thumbnail-fetcher consumed-toggle" data-thumbnail-fetcher-media-type-value="album">
  <%= form_with model: @album do |f| %>
    <% if @album.errors.any? %>
      <div id="error_explanation">
        <h2><%= pluralize(@album.errors.count, "error") %> prohibited this album from being saved:</h2>
        <ul>
        <% @album.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :title %>
      <%= f.text_field :title, required: true, data: { thumbnail_fetcher_target: "titleInput", action: "input->thumbnail-fetcher#search" } %>
    </div>
    <div>
      <%= f.label :artist %>
      <%= f.text_field :artist, data: { thumbnail_fetcher_target: "secondaryInput", action: "input->thumbnail-fetcher#search" } %>
    </div>

    <div class="thumbnail-fetcher-container">
      <label>Thumbnail Cover</label>
      <div class="thumbnail-fetcher-layout">
        <div class="thumbnail-preview-box">
          <img class="thumbnail-preview-img" src="" alt="Cover Preview" style="display: none;" data-thumbnail-fetcher-target="previewImg">
          <div class="thumbnail-preview-placeholder" data-thumbnail-fetcher-target="placeholder">No Cover</div>
        </div>
        <div class="thumbnail-options-box">
          <span class="fetcher-status-text" data-thumbnail-fetcher-target="statusText">Type title to fetch covers...</span>
          <div class="thumbnail-options-grid" data-thumbnail-fetcher-target="optionsGrid"></div>
        </div>
      </div>
      <%= f.hidden_field :thumbnail_url, data: { thumbnail_fetcher_target: "thumbnailUrl" } %>
    </div>

    <div>
      <%= f.label :release_year %>
      <%= f.number_field :release_year %>
    </div>
    <div>
      <%= f.label :genre %>
      <%= f.text_field :genre %>
    </div>

    <div class="form-row-toggles">
      <div class="toggle-field">
        <%= f.check_box :is_collected %>
        <%= f.label :is_collected, "In Collection" %>
      </div>
      <div class="toggle-field">
        <%= f.check_box :in_watchlist %>
        <%= f.label :in_watchlist, "In Watchlist" %>
      </div>
      <div class="toggle-field">
        <%= f.check_box :consumed, data: { consumed_toggle_target: "checkbox", action: "change->consumed-toggle#toggle" } %>
        <%= f.label :consumed, "Listened?" %>
      </div>
    </div>

    <div data-consumed-toggle-target="dateRow" style="display: none;">
      <%= f.label :consumed_at, "Date Listened" %>
      <%= f.date_field :consumed_at, value: Time.current.to_date %>
    </div>

    <div>
      <%= f.label :rating %>
      <%= f.select :rating, [["Unrated", ""], ["½ ★", "0.5"], ["★", "1.0"], ["★½", "1.5"], ["★★", "2.0"], ["★★½", "2.5"], ["★★★", "3.0"], ["★★★½", "3.5"], ["★★★★", "4.0"], ["★★★★½", "4.5"], ["★★★★★", "5.0"]] %>
    </div>

    <div>
      <%= f.label :review %>
      <%= f.text_area :review, rows: 4, placeholder: "Add a review..." %>
    </div>

    <div>
      <%= f.label :is_public, "Make Public?" %>
      <%= f.check_box :is_public %>
    </div>

    <%= f.submit "Create Album" %>
  <% end %>
</div>
