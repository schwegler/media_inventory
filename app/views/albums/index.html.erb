<div class="page-header">
  <h1>Albums</h1>
  <% if logged_in? %>
    <%= link_to 'New Album', new_album_path, class: 'sleek-btn sleek-btn-primary' %>
  <% end %>
</div>

<turbo-frame id="items_list">
  <div class="media-grid-2026">
    <% @albums.each do |album| %>
      <%= render partial: 'shared/media_card', locals: { media_item: album } %>
    <% end %>
  </div>

  <div class="pagination-wrapper">
    <%= paginate @albums %>
  </div>
</turbo-frame>
