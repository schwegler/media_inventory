<div class="page-header">
  <h1>Albums</h1>
  <%= link_to 'New Album', new_album_path, class: 'btn' %>
</div>

<ul class="media-grid">
  <% @albums.each do |album| %>
    <li class="media-card">
      <div class="card-icon">💿</div>
      <div class="card-content">
        <h3><%= link_to album.title, album %></h3>
        <span class="card-meta">Artist: <%= album.artist %></span>
      </div>
    </li>
  <% end %>
</ul>

<div class="pagination-wrapper">
  <%= paginate @albums %>
</div>
