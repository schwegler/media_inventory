<%
  backdrop_url = nil
  if @album.cover_image.attached?
    backdrop_url = url_for(@album.cover_image)
  elsif @album.thumbnail_url.present?
    backdrop_url = @album.thumbnail_url
  end
%>

<div class="show-hero">
  <% if backdrop_url %>
    <div class="show-hero-backdrop" style="background-image: url('<%= backdrop_url %>');"></div>
  <% end %>
  <div class="show-hero-gradient"></div>

  <div class="show-hero-content">
    <div class="show-poster">
      <% if @album.cover_image.attached? %>
        <%= image_tag @album.cover_image, alt: "#{@album.title} Cover" %>
      <% elsif @album.thumbnail_url.present? %>
        <img src="<%= @album.thumbnail_url %>" alt="<%= @album.title %> Cover">
      <% else %>
        <div class="poster-fallback"><span class="fallback-emoji">💿</span></div>
      <% end %>
    </div>

    <div class="show-info">
      <h1 class="show-title"><%= @album.title %></h1>
      <div class="show-meta">
        <span class="show-meta-label">by</span> <%= @album.artist || 'Unknown Artist' %> &bull; <%= @album.genre || 'Various' %> &bull; <%= @album.release_year %>
      </div>

      <% if @album.rating.present? %>
        <div class="show-rating"><%= render_stars(@album.rating) %></div>
      <% end %>

      <div class="show-badges">
        <% if @album.is_collected? %>
          <span class="tracking-badge badge-collected">📁 In Collection</span>
        <% end %>
        <% if @album.in_watchlist? %>
          <span class="tracking-badge badge-watchlist">⏳ Watchlist</span>
        <% end %>
        <% if @album.consumed? %>
          <span class="tracking-badge badge-consumed">
            ✓ Listened <%= "on #{@album.consumed_at.strftime('%b %d, %Y')}" if @album.consumed_at.present? %>
          </span>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="show-content">
  <%= render 'shared/media_actions_and_stream', item: @album %>

  <% if @album.review.present? %>
    <div class="show-review">
      <h3>Review</h3>
      <blockquote><%= simple_format(@album.review) %></blockquote>
    </div>
  <% end %>

  <% stats = community_stats_for(@album) %>
  <div class="show-community">
    <h2>Community</h2>

    <div class="show-stats-bar">
      <div class="show-stat">
        <div class="show-stat-value"><%= stats[:avg_rating] ? "#{stats[:avg_rating]} ★" : "—" %></div>
        <div class="show-stat-label">Average Rating</div>
      </div>
      <div class="show-stat">
        <div class="show-stat-value"><%= stats[:watchers].size %></div>
        <div class="show-stat-label">Listeners</div>
      </div>
      <div class="show-stat">
        <div class="show-stat-value"><%= stats[:collectors].size %></div>
        <div class="show-stat-label">Collectors</div>
      </div>
    </div>

    <% if stats[:reviews].any? %>
      <h3>Community Reviews</h3>
      <div class="show-reviews-list">
        <% stats[:reviews].each do |matching_item| %>
          <div class="show-review-card">
            <div class="review-header">
              <%= user_avatar_tag(matching_item.user, size: 28) %>
              <span class="review-user"><%= matching_item.user.name.presence || matching_item.user.display_handle %></span>
              <% if matching_item.rating.present? %>
                <span class="review-rating"><%= render_stars(matching_item.rating) %></span>
              <% end %>
            </div>
            <div class="review-content"><%= simple_format(matching_item.review) %></div>
            <%= render 'shared/comments_box', matching_item: matching_item %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if stats[:watchers].any? %>
      <h3>Listeners</h3>
      <div class="show-members-list">
        <% stats[:watchers].each do |user| %>
          <span class="show-member-tag"><%= user_avatar_tag(user, size: 20) %> <%= user.name.presence || user.display_handle %></span>
        <% end %>
      </div>
    <% end %>

    <% if stats[:collectors].any? %>
      <h3>Collectors</h3>
      <div class="show-members-list">
        <% stats[:collectors].each do |user| %>
          <span class="show-member-tag"><%= user_avatar_tag(user, size: 20) %> <%= user.name.presence || user.display_handle %></span>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="show-actions">
    <%= link_to '← Back', albums_path, class: 'btn btn-secondary' %>
    <a href="https://open.spotify.com/search/<%= u(@album.title) %>" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">🔗 Find on Spotify</a>
  </div>
</div>
