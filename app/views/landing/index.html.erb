<% if logged_in? %>
  <div class="dashboard-welcome">
    <h1>Welcome back, <span class="welcome-name"><%= current_user.name %></span>. Here’s what your friends have been watching…</h1>
  </div>

  <section class="dashboard-section">
    <div class="section-header">
      <h2>NEW FROM FRIENDS</h2>
      <%= link_to "ALL ACTIVITY", activities_path, class: "section-more-link" rescue "#" %>
    </div>
    
    <div class="media-grid-2026">
      <% @new_from_friends.each do |activity| %>
        <% lib_item = activity.trackable %>
        <% next if lib_item.nil? %>
        <% media = lib_item.is_a?(LibraryItem) ? lib_item.item : lib_item %>
        <%= render partial: 'shared/activity_card', locals: { media_item: media, activity: activity, lib_item: lib_item } %>
      <% end %>
    </div>
  </section>


  <section class="dashboard-section">
    <div class="section-header">
      <h2>POPULAR WITH FRIENDS</h2>
      <span class="section-more-link">MORE</span>
    </div>

    <div class="media-grid-2026">
      <% @popular_items.each do |item| %>
        <% media = item.is_a?(LibraryItem) ? item.item : item %>
        <%= render partial: 'shared/media_card', locals: { media_item: media } %>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-header">
      <h2>POPULAR REVIEWS WITH FRIENDS</h2>
      <span class="section-more-link">MORE</span>
    </div>

    <div class="popular-reviews-layout">
      <% if @popular_reviews.any? %>
        <% @popular_reviews.each do |activity| %>
          <% lib_item = activity.trackable %>
          <% next if lib_item.nil? %>
          <% media = lib_item.is_a?(LibraryItem) ? lib_item.item : lib_item %>
          <div class="popular-review-row">
            <div class="review-poster-col">
              <div class="review-poster">
                <% if media.respond_to?(:cover_image) && media.cover_image.attached? %>
                  <%= image_tag media.cover_image, alt: media.title, class: 'poster-img' %>
                <% elsif media.respond_to?(:thumbnail_url) && media.thumbnail_url.present? %>
                  <img src="<%= media.thumbnail_url %>" alt="<%= media.title %>" class="poster-img">
                <% else %>
                  <div class="poster-fallback">
                    <span class="fallback-emoji">
                      <%= case media.class.name
                          when 'Movie' then '🎬'
                          when 'Album' then '💿'
                          when 'Comic' then '📚'
                          when 'TvShow' then '📺'
                          when 'VideoGame' then '🎮'
                          else '📦'
                          end %>
                    </span>
                  </div>
                <% end %>
                <%= link_to "", media, class: "stretched-link", aria: { label: "View #{media.title}" } %>
              </div>
            </div>

            <div class="review-body-col">
              <div class="review-author-header">
                <%= user_avatar_tag(activity.user, size: 24) %>
                <span class="review-author-name"><%= link_to activity.user.name, activity.user %></span>
                <span class="review-target-title">
                  <%= link_to media.title, media %>
                  <% if media.respond_to?(:release_year) && media.release_year.present? %>
                    <span class="review-year"><%= media.release_year %></span>
                  <% end %>
                </span>
              </div>

              <div class="review-rating-row">
                <% if lib_item.respond_to?(:rating) && lib_item.rating.present? %>
                  <span class="review-stars"><%= render_stars(lib_item.rating) %></span>
                <% end %>
                <% if lib_item.respond_to?(:rating) && lib_item.rating.to_f >= 4.0 %>
                  <span class="heart-icon">🧡</span>
                <% end %>
                <% mock_comment_count = (activity.id * 3) % 12 + 1 %>
                <span class="comments-count"><span class="chat-icon">💬</span> <%= mock_comment_count %></span>
              </div>

              <div class="review-content-text">
                <p>"<%= truncate(lib_item.respond_to?(:review) ? lib_item.review : '', length: 240) %>"</p>
                <% if lib_item.respond_to?(:review) && lib_item.review.present? && lib_item.review.length > 240 %>
                  <%= link_to "more", media, class: "more-review-link" %>
                <% end %>
              </div>

              <div class="review-like-action">
                <%= render 'likes/like_button', item: media %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="details-card" style="text-align: center; padding: 2rem;">
          <p>No popular reviews yet. Add some reviews to get started!</p>
        </div>
      <% end %>
    </div>
  </section>

<% else %>
  <%# Standard Landing Page for Non-Logged-In Users %>
  <div class="page-header">
    <h1>Community Activity</h1>
  </div>

  <div class="dashboard-layout">
    <div class="activity-feed-section">
      <% if @activities.any? %>
        <turbo-frame id="activity_feed">
          <div class="activity-feed">
            <% @activities.each do |activity| %>
              <% trackable = activity.trackable %>
              <% media = trackable.is_a?(LibraryItem) ? trackable.item : trackable %>
              <div class="activity-card">
                <div class="activity-thumbnail">
                  <% if media.respond_to?(:thumbnail_url) && media.thumbnail_url.present? %>
                    <img src="<%= media.thumbnail_url %>" alt="Cover">
                  <% else %>
                    <span class="fallback-icon">
                      <%= case media&.class&.name
                          when 'Movie' then '🎬'
                          when 'Album' then '💿'
                          when 'Comic' then '📚'
                          when 'TvShow' then '📺'
                          when 'VideoGame' then '🎮'
                          else '📦'
                          end %>
                    </span>
                  <% end %>
                </div>
                
                <div class="activity-body">
                  <div style="display: flex; gap: 10px; align-items: start;">
                    <%= user_avatar_tag(activity.user, size: 32) %>
                    <div class="activity-header" style="flex: 1;">
                      <span class="activity-text">
                        <%= activity_link_description(activity) %>
                      </span>
                      <% if trackable.respond_to?(:review) && trackable.review.present? && activity.activity_type == 'reviewed' %>
                        <div class="activity-review-quote">
                          "<%= truncate(trackable.review, length: 150) %>"
                        </div>
                      <% end %>
                    </div>
                  </div>
                  
                  <div class="activity-footer">
                    <div style="display: flex; gap: 12px; align-items: center;">
                      <span class="activity-badge badge-<%= activity.activity_type %>">
                        <%= activity.activity_type %>
                      </span>
                      <span class="activity-time">
                        <%= time_ago_in_words(activity.created_at) %> ago
                      </span>
                    </div>
                    <div class="activity-actions">
                      <%= render partial: 'likes/like_button', locals: { item: activity, tweet_style: true } %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
          
          <div class="pagination-wrapper">
            <%= paginate @activities %>
          </div>
        </turbo-frame>
      <% else %>
        <div class="details-card" style="text-align: center; padding: 3rem;">
          <h3 style="margin-bottom: 10px;">No Recent Activity</h3>
          <p>Start by adding or reviewing items in your collection!</p>
        </div>
      <% end %>
    </div>

    <div class="dashboard-sidebar">
      <div class="sidebar-widget">
        <h3>Welcome to MediaTracker</h3>
        <p>Log your movies, albums, books, tv progress, and more. Pull cover art automatically and see what others are tracking!</p>
      </div>

      <div class="sidebar-widget">
        <h3>Active Trackers</h3>
        <div class="sidebar-user-list">
          <% @active_trackers.each do |user| %>
            <div class="sidebar-user-item">
              <%= user_avatar_tag(user, size: 24) %>
              <%= link_to user.name, user %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
