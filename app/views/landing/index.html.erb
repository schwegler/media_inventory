<div class="page-header">
  <h1>Community Activity</h1>
  <% if logged_in? %>
    <div style="display: flex; gap: 8px;">
      <%= link_to 'Add Movie', new_movie_path, class: 'btn btn-sm btn-secondary' %>
      <%= link_to 'Add Album', new_album_path, class: 'btn btn-sm btn-secondary' %>
    </div>
  <% end %>
</div>

<div class="dashboard-layout">
  <div class="activity-feed-section">
    <% if @activities.any? %>
      <turbo-frame id="activity_feed">
        <div class="activity-feed">
          <% @activities.each do |activity| %>
            <% trackable = activity.trackable %>
            <div class="activity-card">
              <div class="activity-thumbnail">
                <% if trackable&.thumbnail_url.present? %>
                  <img src="<%= trackable.thumbnail_url %>" alt="Cover">
                <% else %>
                  <span class="fallback-icon">
                    <%= case activity.trackable_type
                        when 'Movie' then '🎬'
                        when 'Album' then '💿'
                        when 'Comic' then '📚'
                        when 'TvShow' then '📺'
                        when 'WrestlingEvent' then '🤼'
                        else '📦'
                        end %>
                  </span>
                <% end %>
              </div>
              
              <div class="activity-body">
                <div class="activity-header">
                  <span class="activity-text">
                    <%= activity_link_description(activity) %>
                  </span>
                  <% if trackable&.review.present? && activity.activity_type == 'reviewed' %>
                    <div class="activity-review-quote">
                      "<%= truncate(trackable.review, length: 150) %>"
                    </div>
                  <% end %>
                </div>
                
                <div class="activity-footer">
                  <span class="activity-badge badge-<%= activity.activity_type %>">
                    <%= activity.activity_type %>
                  </span>
                  <span class="activity-time">
                    <%= time_ago_in_words(activity.created_at) %> ago
                  </span>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        
        <div class="pagination-wrapper">
          <%= paginate @activities %>
        </div>
      </turbo-frame>
    <% else %>
      <div class="details-card" style="text-align: center; padding: 3rem;">
        <h3 style="margin-bottom: 10px;">No Recent Activity</h3>
        <p>Start by adding or reviewing items in your collection!</p>
      </div>
    <% end %>
  </div>

  <div class="dashboard-sidebar">
    <div class="sidebar-widget">
      <h3>Welcome to MediaTracker</h3>
      <p>Log your movies, albums, books, tv progress, and more. Pull cover art automatically and see what others are tracking!</p>
    </div>

    <div class="sidebar-widget">
      <h3>Active Trackers</h3>
      <div class="sidebar-user-list">
        <% @active_trackers.each do |user| %>
          <div class="sidebar-user-item">
            <span class="user-avatar-sm">👤</span>
            <%= link_to user.name, user %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
