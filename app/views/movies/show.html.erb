<div class="details-card" style="max-width: 700px;">
  <div class="media-item-header">
    <div class="media-item-cover">
      <% if @movie.thumbnail_url.present? %>
        <img src="<%= @movie.thumbnail_url %>" alt="<%= @movie.title %> Cover">
      <% else %>
        <span class="fallback-icon">🎬</span>
      <% end %>
    </div>
    
    <div class="media-item-details">
      <h1><%= @movie.title %></h1>
      <div class="media-sub-meta">Director: <%= @movie.director || 'Unknown' %> &bull; <%= @movie.release_year %></div>
      
      <div class="media-tracking-badges">
        <% if @movie.is_collected? %>
          <span class="tracking-badge badge-collected">📁 In Collection</span>
        <% end %>
        <% if @movie.in_watchlist? %>
          <span class="tracking-badge badge-watchlist">⏳ Watchlist</span>
        <% end %>
        <% if @movie.consumed? %>
          <span class="tracking-badge badge-consumed">
            ✓ Watched <%= "on #{@movie.consumed_at.strftime('%b %d, %Y')}" if @movie.consumed_at.present? %>
          </span>
        <% end %>
      </div>

      <% if @movie.rating.present? %>
        <div class="detail-row" style="border-bottom: none; padding: 0;">
          <strong>Rating:</strong>
          <span style="font-size: 1.2rem; color: #facc15;"><%= @movie.rating %> ★</span>
        </div>
      <% end %>
    </div>
  </div>

  <% if @movie.review.present? %>
    <div class="media-review-box">
      <h3>Review</h3>
      <p><%= simple_format(@movie.review) %></p>
    </div>
  <% end %>

  <div class="actions" style="margin-top: 2rem;">
    <%= link_to 'Back', movies_path, class: 'btn btn-secondary' %>
  </div>
</div>
