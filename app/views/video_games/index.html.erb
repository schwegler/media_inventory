<div class="page-header">
  <h1>Video Games</h1>
  <% if logged_in? %>
    <%= link_to 'New Video Game', new_video_game_path, class: 'sleek-btn sleek-btn-primary' %>
  <% end %>
</div>

<div class="media-grid-2026">
  <% @video_games.each do |video_game| %>
    <%= render partial: 'shared/media_card', locals: { media_item: video_game } %>
  <% end %>
</div>

<div class="pagination-wrapper">
  <%= paginate @video_games %>
</div>
