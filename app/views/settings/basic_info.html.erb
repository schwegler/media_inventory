<div class="settings-container">
  <%= render 'sidebar' %>

  <div class="settings-content">
    <h1 class="settings-title">Basic Information</h1>

    <%= form_with(model: @user, url: settings_update_basic_info_path, local: true, class: "settings-form") do |f| %>
      <%= render 'shared/error_messages', object: f.object %>

      <div class="form-group">
        <%= f.label :username %>
        <%= f.text_field :username, class: 'form-control', placeholder: 'Enter username' %>
      </div>

      <div class="form-group">
        <%= f.label :name, "Display Name" %>
        <%= f.text_field :name, class: 'form-control', placeholder: 'Enter display name' %>
      </div>

      <div class="form-group">
        <%= f.label :birthday %>
        <%= f.date_field :birthday, class: 'form-control' %>
      </div>

      <div class="form-group">
        <%= f.label :bio %>
        <%= f.text_area :bio, class: 'form-control', rows: 4, placeholder: 'Tell us about yourself' %>
      </div>

      <div class="form-group">
        <label>Profile Image</label>
        <div class="image-upload-wrapper">
          <div class="current-avatar">
            <%= user_avatar_tag(@user, size: 80) %>
          </div>
          <%= f.file_field :avatar, class: 'file-input' %>
        </div>
      </div>

      <div class="form-group">
        <label>Header Image</label>
        <div class="image-upload-wrapper header-upload">
          <% if @user.header_banner.attached? %>
            <%= image_tag @user.header_banner, class: 'current-header-preview' %>
          <% else %>
            <div class="header-placeholder">No header image set</div>
          <% end %>
          <%= f.file_field :header_banner, class: 'file-input' %>
        </div>
      </div>

      <div class="form-actions">
        <%= f.submit "Save Changes", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
