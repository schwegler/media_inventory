<h1>Log in</h1>

<div class="row">
  <div class="col-md-6 col-md-offset-3">
    <%= form_with(url: login_path, scope: :session, class: "standard-form") do |f| %>
      <div class="form-group">
        <%= f.label :email %>
        <%= f.email_field :email, class: 'form-control', required: true %>
      </div>

      <div class="form-group" style="margin-top: 15px;">
        <%= f.label :password %>
        <%= f.password_field :password, class: 'form-control', required: true %>
      </div>

      <%= f.submit "Log in", class: "btn btn-primary", style: "margin-top: 20px;" %>
    <% end %>

    <p style="margin-top: 20px; text-align: center;">
      New user? <%= link_to "Sign up now!", signup_path %>
    </p>

    <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.08); margin: 2rem 0;">

    <h2 style="font-size: 1.25rem; text-align: center; margin-bottom: 1.5rem;">🦋 Log in with Bluesky</h2>
    
    <%= form_with(url: sessions_bsky_login_path, local: true, class: "standard-form") do |f| %>
      <div class="form-group">
        <%= f.label :bsky_handle, "Bluesky Handle" %>
        <%= f.text_field :bsky_handle, class: 'form-control', placeholder: 'e.g. username.bsky.social', required: true %>
      </div>

      <div class="form-group" style="margin-top: 15px;">
        <%= f.label :bsky_app_password, "Bluesky App Password" %>
        <%= f.password_field :bsky_app_password, class: 'form-control', placeholder: 'e.g. xxxx-xxxx-xxxx-xxxx', required: true %>
      </div>

      <%= f.submit "Log in with Bluesky", class: "btn btn-secondary", style: "margin-top: 20px; width: 100%; background: #0284c7; border: none; color: #fff;" %>
    <% end %>
  </div>
</div>
