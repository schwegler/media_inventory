<h1>Log in</h1>

<div class="row">
  <div class="col-md-6 col-md-offset-3">
    <div data-controller="tabs" class="auth-tabs-container">
      <div class="auth-tabs">
        <button type="button" class="auth-tab active" data-tabs-target="tab" data-tab-name="email" data-action="click->tabs#switch">Email</button>
        <button type="button" class="auth-tab" data-tabs-target="tab" data-tab-name="bsky-oauth" data-action="click->tabs#switch">Bluesky</button>
        <button type="button" class="auth-tab" data-tabs-target="tab" data-tab-name="mastodon" data-action="click->tabs#switch">Mastodon</button>
        <button type="button" class="auth-tab" data-tabs-target="tab" data-tab-name="bsky-app" data-action="click->tabs#switch">Bluesky (App Password)</button>
      </div>

      <div class="auth-tab-content" data-tabs-target="content" data-tab-name="email">
        <h2 class="auth-section-title">Log in with Email</h2>
        <div class="auth-section-body">
          <%= form_with(url: login_path, scope: :session, class: "standard-form") do |f| %>
            <div class="form-group">
              <%= f.label :email %>
              <%= f.email_field :email, class: 'form-control', required: true %>
            </div>
            <div class="form-group password-group">
              <%= f.label :password %>
              <%= f.password_field :password, class: 'form-control', required: true %>
            </div>
            <div class="submit-group">
              <%= f.submit "Log in", class: "sleek-btn sleek-btn-primary auth-submit" %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="auth-tab-content hidden" data-tabs-target="content" data-tab-name="bsky-oauth">
        <h2 class="auth-section-title">🦋 Log in with Bluesky</h2>
        <div class="auth-section-body">
          <%= form_tag "/auth/atproto", method: :post, data: { turbo: false } do %>
            <div class="form-group handle-group">
              <%= label_tag :bsky_handle, "Bluesky Handle" %>
              <%= text_field_tag :bsky_handle, nil, class: 'form-control', placeholder: 'e.g. alice.bsky.social', required: true %>
            </div>
            <%= submit_tag "Log in via Bluesky", class: "sleek-btn sleek-btn-secondary bsky-btn" %>
          <% end %>
        </div>
      </div>

      <div class="auth-tab-content hidden" data-tabs-target="content" data-tab-name="mastodon">
        <h2 class="auth-section-title">🐘 Log in with Mastodon</h2>
        <div class="auth-section-body">
          <%= form_tag "/auth/mastodon", method: :post, data: { turbo: false } do %>
            <div class="form-group server-group">
              <%= label_tag :mastodon_server, "Mastodon Server URL" %>
              <%= text_field_tag :mastodon_server, nil, class: 'form-control', placeholder: 'e.g. mastodon.social', required: true %>
            </div>
            <%= submit_tag "Log in via Mastodon", class: "sleek-btn sleek-btn-secondary mastodon-btn" %>
          <% end %>
        </div>
      </div>

      <div class="auth-tab-content hidden" data-tabs-target="content" data-tab-name="bsky-app">
        <h2 class="auth-section-title">🦋 Bluesky App Password</h2>
        <div class="auth-section-body">
          <%= form_with(url: login_path, scope: :session, class: "standard-form") do |f| %>
            <div class="form-group handle-group">
              <%= f.label :bsky_handle, "Bluesky Handle" %>
              <%= f.text_field :bsky_handle, class: 'form-control', placeholder: 'e.g. alice.bsky.social', required: true %>
            </div>
            <div class="form-group password-group">
              <%= f.label :bsky_password, "App Password" %>
              <%= f.password_field :bsky_password, class: 'form-control', placeholder: 'xxxx-xxxx-xxxx-xxxx', required: true %>
            </div>
            <div class="submit-group">
              <%= f.submit "Log in with App Password", class: "sleek-btn sleek-btn-secondary bsky-btn" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    
    <hr class="auth-divider">
    <p class="auth-signup-prompt">
      New user? <%= link_to "Sign up now!", signup_path %>
    </p>
  </div>
</div>
